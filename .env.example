# MongoDB Atlas connection string (free M0 cluster)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/kalashree?retryWrites=true&w=majority

# JWT secret for signing tokens (user + admin)
JWT_SECRET=replace_this_with_a_long_random_string

# Resend (free tier email API) - https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Kalashree Music Classes <onboarding@resend.dev>

# Admin bootstrap (used by seed script to create the first admin)
ADMIN_EMAIL=admin@kalashreemusic.com
ADMIN_PASSWORD=ChangeMe@123

# UPI ID that receives payments - QR is generated with this + amount embedded
UPI_ID=kalashreemusic@okhdfcbank
UPI_PAYEE_NAME=Kalashree Music Classes

# Server
PORT=5000
# Comma-separated list of allowed frontend origins (public site + admin subdomain)
CLIENT_URLS=http://localhost:5173,http://localhost:5174
