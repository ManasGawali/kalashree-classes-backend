# ==========================================
# Dependencies & Package Managers
# ==========================================
# Blocks heavy node_modules folders for both frontend and backend
node_modules/
.pnp
.pnp.js
jspm_packages/

# ==========================================
# Environment Variables & Secrets (CRITICAL)
# ==========================================
# Never commit raw credentials, API keys, or database URIs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
.env.*
!*.env.example

# ==========================================
# Production / Build Artifacts
# ==========================================
# React / Frontend build directories
dist/
build/
out/

# Node.js backend build directories (if using TypeScript/Babel)
lib/
bin/

# ==========================================
# Logs and Diagnostics
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# Testing and Coverage
# ==========================================
coverage/
.nyc_output/

# ==========================================
# IDEs, Editors, & System Files
# ==========================================
.eslintcache
.stylelintcache
.project
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
Thumbs.db